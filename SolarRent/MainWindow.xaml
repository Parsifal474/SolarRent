<Window x:Class="SolarRent.MainDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Главная панель" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2E2EFF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#86EFAC"/>
        <SolidColorBrush x:Key="GrayBackground" Color="#E8E8E8"/>

        <!-- Стиль для карточек статистики -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для кнопок быстрых действий -->
        <Style x:Key="QuickActionButton" TargetType="Button">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточки заказа -->
        <Style x:Key="OrderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>

        <!-- Стиль для кнопки статуса -->
        <Style x:Key="StatusButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для серой кнопки -->
        <Style x:Key="GrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9E9E9E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlue}" Padding="20,15">
            <TextBlock Text="Главная панель" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Карточки статистики -->
        <Border Grid.Row="1" Background="White" Padding="20,15" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Всего заказов -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Всего заказов" Style="{StaticResource StatTitleStyle}"/>
                        <TextBlock Text="2312" Style="{StaticResource StatValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Общая сумма -->
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Общая сумма" Style="{StaticResource StatTitleStyle}"/>
                        <TextBlock Text="2,345,342" Style="{StaticResource StatValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 3: Просрочен -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Просрочен" Style="{StaticResource StatTitleStyle}"/>
                        <TextBlock Text="0" Style="{StaticResource StatValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Новые клиенты -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Новые клиенты" Style="{StaticResource StatTitleStyle}"/>
                        <TextBlock Text="0" Style="{StaticResource StatValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 5: Выручка за месяц -->
                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Выручка за месяц" Style="{StaticResource StatTitleStyle}"/>
                        <TextBlock Text="0" Style="{StaticResource StatValueStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Последние заказы -->
            <Border Grid.Column="0" Background="{StaticResource GrayBackground}" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Последние заказы" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#555555"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Order Card 1 -->
                            <Border Style="{StaticResource OrderCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34,444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Солнечная панель 300W" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Заказ №2323" 
                                               FontSize="13"
                                               Foreground="#888888"/>
                                    <Button Grid.Row="2" Grid.Column="1" 
                                            Content="Возвращено"
                                            Style="{StaticResource StatusButtonStyle}"
                                            HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Order Card 2 -->
                            <Border Style="{StaticResource OrderCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34,444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Солнечная панель 300W" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Заказ №2323" 
                                               FontSize="13"
                                               Foreground="#888888"/>
                                    <Button Grid.Row="2" Grid.Column="1" 
                                            Content="Возвращено"
                                            Style="{StaticResource StatusButtonStyle}"
                                            HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Order Card 3 -->
                            <Border Style="{StaticResource OrderCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34,444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Солнечная панель 300W" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Заказ №2323" 
                                               FontSize="13"
                                               Foreground="#888888"/>
                                    <Button Grid.Row="2" Grid.Column="1" 
                                            Content="Возвращено"
                                            Style="{StaticResource StatusButtonStyle}"
                                            HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" 
                            Content="Показать все заказы"
                            Style="{StaticResource GrayButtonStyle}"
                            Margin="0,15,0,0"/>
                </Grid>
            </Border>

            <!-- Правая панель - Быстрые действия -->
            <Border Grid.Column="1" Background="{StaticResource GrayBackground}" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Быстрые действия" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#555555"
                               Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1">
                        <Button Content="Календарь аренды" Style="{StaticResource QuickActionButton}" Click="CalendarButton_Click"/>
                        <Button Content="Добавить клиента" Style="{StaticResource QuickActionButton}" Click="AddClientButton_Click"/>
                        <Button Content="Новая аренда" Style="{StaticResource QuickActionButton}"/>
                        <Button Content="Отчеты" Style="{StaticResource QuickActionButton}"/>
                        <Button Content="Каталог" Style="{StaticResource QuickActionButton}" Click="CatalogButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>