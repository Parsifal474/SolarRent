<Window x:Class="SolarRent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Автоматизация продажи и аренды оборудования"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Каталог" Command="{Binding OpenCatalogCommand}"/>
            <MenuItem Header="Аренда" Command="{Binding OpenRentalCommand}"/>
            <MenuItem Header="Клиенты" Command="{Binding OpenClientsCommand}"/>
            <MenuItem Header="Отчёты" Command="{Binding OpenReportsCommand}"/>
        </Menu>

        <Frame Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Content="{Binding CurrentView}"/>
    </Grid>
</Window>