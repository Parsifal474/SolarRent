<Window x:Class="SolarRent.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Автоматизация аренды" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Каталог" Command="{Binding OpenCatalogCommand}"/>
            <MenuItem Header="Аренда" Command="{Binding OpenRentalCommand}"/>
            <MenuItem Header="Клиенты" Command="{Binding OpenClientsCommand}"/>
            <MenuItem Header="Отчеты" Command="{Binding OpenReportsCommand}"/>
        </Menu>

        <Frame Grid.Row="1" NavigationUIVisibility="Hidden" Content="{Binding CurrentView}"/>
    </Grid>
</Window>