<Window x:Class="SolarRent.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Вход в систему" 
        Height="600" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Стиль для заголовка -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для полей ввода -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Стиль для поля пароля -->
        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Стиль для ComboBox (роль) -->
        <Style x:Key="RoleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Стиль для кнопки входа -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E2EFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1aff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2E2EFF" Padding="0,15">
            <TextBlock Text="SolarRent" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основная форма -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Подзаголовок -->
                <TextBlock Grid.Row="0" 
                           Text="Система управления арендой" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Foreground="#5A7FBF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Поле Логин -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Логин" Style="{StaticResource HeaderTextStyle}"/>
                    <TextBox x:Name="txtLogin" Style="{StaticResource InputTextBoxStyle}"/>
                </StackPanel>

                <!-- Поле Пароль -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Пароль" Style="{StaticResource HeaderTextStyle}"/>
                    <PasswordBox x:Name="pwdPassword" Style="{StaticResource PasswordBoxStyle}"/>
                </StackPanel>

                <!-- Выбор роли -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Роль" Style="{StaticResource HeaderTextStyle}"/>
                    <ComboBox x:Name="cmbRole" Style="{StaticResource RoleComboBoxStyle}">
                        <ComboBoxItem Content="Менеджер по продажам"/>
                        <ComboBoxItem Content="Складской работник"/>
                        <ComboBoxItem Content="Директор"/>
                        <ComboBoxItem Content="Бухгалтерия"/>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопка входа -->
                <Button Grid.Row="4" 
                        Content="Войти в систему" 
                        Style="{StaticResource LoginButtonStyle}"
                        Click="LoginButton_Click"/>

                <!-- Информация о ролях (опционально, можно скрыть) -->
                <Border Grid.Row="5" 
                        Background="#E8E8E8" 
                        CornerRadius="5" 
                        Padding="10" 
                        Margin="0,20,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Список ролей:" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="1. Менеджер по продажам" FontSize="12" Foreground="#666666"/>
                        <TextBlock Text="2. Складской работник" FontSize="12" Foreground="#666666"/>
                        <TextBlock Text="3. Директор" FontSize="12" Foreground="#666666"/>
                        <TextBlock Text="4. Бухгалтерия" FontSize="12" Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>