<Window x:Class="SolarRent.AddEquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Добавить оборудование" 
        Height="600" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Стиль для заголовков -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Стиль для полей ввода -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E2EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1aff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2E2EFF" Padding="20,15">
            <TextBlock Text="Добавить оборудование" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" Padding="30" Margin="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Название -->
                    <TextBlock Text="Название *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtName" Style="{StaticResource InputStyle}"/>

                    <!-- Тип -->
                    <TextBlock Text="Тип *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbType" Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="Панель"/>
                        <ComboBoxItem Content="Инвертор"/>
                        <ComboBoxItem Content="Аккумулятор"/>
                        <ComboBoxItem Content="Контроллер"/>
                        <ComboBoxItem Content="Другое"/>
                    </ComboBox>

                    <!-- Мощность -->
                    <TextBlock Text="Мощность *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtPower" Style="{StaticResource InputStyle}"/>

                    <!-- Цена/день -->
                    <TextBlock Text="Цена/день (₽) *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtPricePerDay" Style="{StaticResource InputStyle}"/>

                    <!-- Залог -->
                    <TextBlock Text="Залог (₽) *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtDeposit" Style="{StaticResource InputStyle}"/>

                    <!-- Описание -->
                    <TextBlock Text="Описание" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtDescription" 
                             Height="100" 
                             Margin="0,0,0,15"
                             Padding="10"
                             FontSize="14"
                             BorderThickness="1"
                             BorderBrush="#D1D5DB"
                             Background="White"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="2" Padding="30,20" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" 
                        Content="Отмена" 
                        Style="{StaticResource CancelButtonStyle}"
                        Width="120"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="2" 
                        Content="Сохранить" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="150"
                        Click="SaveButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>