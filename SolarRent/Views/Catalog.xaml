<Window x:Class="SolarRent.Catalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Каталог оборудования" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2E2EFF"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E8E8FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#86EFAC"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#FDBA74"/>
        <SolidColorBrush x:Key="InfoPurple" Color="#C4B5FD"/>

        <!-- Стиль заголовка -->
        <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2E2EFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль поля поиска -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль фильтра-тега -->
        <Style x:Key="FilterTagStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WarningOrange}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Стиль карточки оборудования -->
        <Style x:Key="EquipmentCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки действия -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2E2EFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки пагинации -->
        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PaginationActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource PaginationButtonStyle}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlue}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Каталог оборудования" 
                           Style="{StaticResource HeaderTitleStyle}"/>

                <Button Grid.Column="1" 
                        Content="+ Добавить оборудование" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Поиск и фильтры -->
        <Grid Grid.Row="1" Margin="20,15,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" 
                     Text="Поиск по названию, типу, характеристикам..."
                     Style="{StaticResource SearchTextBoxStyle}"
                     Foreground="#9CA3AF"/>

            <Button Grid.Column="1" 
                    Content="Фильтры" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0"/>

            <Button Grid.Column="2" 
                    Content="Экспорт" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0"/>
        </Grid>

        <!-- Активные фильтры -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,15">
            <TextBlock Text="Фильтры:" 
                       FontSize="14" 
                       FontWeight="Medium"
                       Foreground="#374151"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <Border Style="{StaticResource FilterTagStyle}">
                <TextBlock Text="Тип: Панель" 
                           Foreground="#C2410C"
                           FontSize="13"
                           FontWeight="Medium"/>
            </Border>

            <Border Style="{StaticResource FilterTagStyle}" Background="{StaticResource InfoPurple}">
                <TextBlock Text="Статус: в наличии" 
                           Foreground="#5B21B6"
                           FontSize="13"
                           FontWeight="Medium"/>
            </Border>
        </StackPanel>

        <!-- Сетка оборудования -->
        <ItemsControl Grid.Row="3" Margin="10,0,10,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Карточка 1: Солнечная панель 300w -->
            <Border Style="{StaticResource EquipmentCardStyle}" Width="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Иконка солнца -->
                    <Border Grid.Row="0" 
                            Background="#F0FDF4" 
                            CornerRadius="8" 
                            Height="120"
                            Margin="-15,-15,-15,15">
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#FBBF24" StrokeThickness="2">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <EllipseGeometry Center="12,12" RadiusX="5" RadiusY="5"/>
                                            <LineGeometry StartPoint="12,1" EndPoint="12,5"/>
                                            <LineGeometry StartPoint="12,19" EndPoint="12,23"/>
                                            <LineGeometry StartPoint="1,12" EndPoint="5,12"/>
                                            <LineGeometry StartPoint="19,12" EndPoint="23,12"/>
                                            <LineGeometry StartPoint="3.5,3.5" EndPoint="6.5,6.5"/>
                                            <LineGeometry StartPoint="17.5,17.5" EndPoint="20.5,20.5"/>
                                            <LineGeometry StartPoint="3.5,20.5" EndPoint="6.5,17.5"/>
                                            <LineGeometry StartPoint="17.5,6.5" EndPoint="20.5,3.5"/>
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Название -->
                    <TextBlock Grid.Row="1" 
                               Text="Солнечная панель 300w" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                    <!-- Характеристики -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="Панель" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мощность:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="300w" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цена/день:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 1,500" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Залог:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 3,000" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>

                    <!-- Статус -->
                    <Border Grid.Row="3" 
                            Background="{StaticResource SuccessGreen}" 
                            CornerRadius="6" 
                            Padding="8,4"
                            Margin="0,0,0,10">
                        <TextBlock Text="В наличии" 
                                   Foreground="#166534" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Кнопки действий -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="✎ Изменить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Left"
                                Foreground="#7C3AED"/>

                        <Button Grid.Column="1" 
                                Content="🗑 Удалить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Right"
                                Foreground="#EF4444"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Карточка 2: Инвертор 5kW -->
            <Border Style="{StaticResource EquipmentCardStyle}" Width="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Иконка молнии -->
                    <Border Grid.Row="0" 
                            Background="#EFF6FF" 
                            CornerRadius="8" 
                            Height="120"
                            Margin="-15,-15,-15,15">
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#FBBF24" Stroke="#F59E0B" StrokeThickness="1">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="12,2" IsClosed="True">
                                                <LineSegment Point="14,10"/>
                                                <LineSegment Point="22,10"/>
                                                <LineSegment Point="15,16"/>
                                                <LineSegment Point="17,24"/>
                                                <LineSegment Point="10,18"/>
                                                <LineSegment Point="3,22"/>
                                                <LineSegment Point="7,14"/>
                                                <LineSegment Point="1,8"/>
                                                <LineSegment Point="9,8"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Grid.Row="1" 
                               Text="Инвертор 5kW" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="Панель" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мощность:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="5kW" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цена/день:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 1,500" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Залог:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 3,000" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="3" 
                            Background="{StaticResource SuccessGreen}" 
                            CornerRadius="6" 
                            Padding="8,4"
                            Margin="0,0,0,10">
                        <TextBlock Text="В наличии" 
                                   Foreground="#166534" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="✎ Изменить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Left"
                                Foreground="#7C3AED"/>

                        <Button Grid.Column="1" 
                                Content="🗑 Удалить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Right"
                                Foreground="#EF4444"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Карточка 3: Аккумулятор 10kWh -->
            <Border Style="{StaticResource EquipmentCardStyle}" Width="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Иконка батареи -->
                    <Border Grid.Row="0" 
                            Background="#FEF3E2" 
                            CornerRadius="8" 
                            Height="120"
                            Margin="-15,-15,-15,15">
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="6" Canvas.Top="2" Width="12" Height="20" 
                                         Fill="#22C55E" Stroke="#16A34A" StrokeThickness="1" RadiusX="2" RadiusY="2"/>
                                <Rectangle Canvas.Left="10" Canvas.Top="0" Width="4" Height="2" Fill="#16A34A"/>
                                <Rectangle Canvas.Left="8" Canvas.Top="6" Width="8" Height="10" Fill="#86EFAC" Opacity="0.6"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Grid.Row="1" 
                               Text="Аккумулятор 10kWh" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="Панель" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мощность:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="10kWh" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цена/день:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 1,500" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Залог:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 3,000" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="3" 
                            Background="{StaticResource SuccessGreen}" 
                            CornerRadius="6" 
                            Padding="8,4"
                            Margin="0,0,0,10">
                        <TextBlock Text="В наличии" 
                                   Foreground="#166534" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="✎ Изменить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Left"
                                Foreground="#7C3AED"/>

                        <Button Grid.Column="1" 
                                Content="🗑 Удалить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Right"
                                Foreground="#EF4444"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Карточка 4: Солнечная панель 490w -->
            <Border Style="{StaticResource EquipmentCardStyle}" Width="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Иконка солнца -->
                    <Border Grid.Row="0" 
                            Background="#F0FDF4" 
                            CornerRadius="8" 
                            Height="120"
                            Margin="-15,-15,-15,15">
                        <Viewbox Width="60" Height="60">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#FBBF24" StrokeThickness="2">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <EllipseGeometry Center="12,12" RadiusX="5" RadiusY="5"/>
                                            <LineGeometry StartPoint="12,1" EndPoint="12,5"/>
                                            <LineGeometry StartPoint="12,19" EndPoint="12,23"/>
                                            <LineGeometry StartPoint="1,12" EndPoint="5,12"/>
                                            <LineGeometry StartPoint="19,12" EndPoint="23,12"/>
                                            <LineGeometry StartPoint="3.5,3.5" EndPoint="6.5,6.5"/>
                                            <LineGeometry StartPoint="17.5,17.5" EndPoint="20.5,20.5"/>
                                            <LineGeometry StartPoint="3.5,20.5" EndPoint="6.5,17.5"/>
                                            <LineGeometry StartPoint="17.5,6.5" EndPoint="20.5,3.5"/>
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <TextBlock Grid.Row="1" 
                               Text="Солнечная панель 490w" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="Панель" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мощность:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="300w" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цена/день:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 1,500" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Залог:" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Column="1" Text="₽ 3,000" FontSize="12" Foreground="#374151" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="3" 
                            Background="{StaticResource SuccessGreen}" 
                            CornerRadius="6" 
                            Padding="8,4"
                            Margin="0,0,0,10">
                        <TextBlock Text="В наличии" 
                                   Foreground="#166534" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="✎ Изменить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Left"
                                Foreground="#7C3AED"/>

                        <Button Grid.Column="1" 
                                Content="🗑 Удалить" 
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Right"
                                Foreground="#EF4444"/>
                    </Grid>
                </Grid>
            </Border>
        </ItemsControl>

        <!-- Футер с пагинацией -->
        <Grid Grid.Row="4" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="Показано 4 из 24 единиц оборудования" 
                       FontSize="14" 
                       Foreground="#374151"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Назад" 
                        Style="{StaticResource PaginationButtonStyle}"
                        Width="80"
                        Margin="0,0,5,0"/>

                <Button Content="1" 
                        Style="{StaticResource PaginationActiveButtonStyle}"
                        Margin="0,0,5,0"/>

                <Button Content="2" 
                        Style="{StaticResource PaginationButtonStyle}"
                        Margin="0,0,5,0"/>

                <Button Content="3" 
                        Style="{StaticResource PaginationButtonStyle}"
                        Margin="0,0,5,0"/>

                <Button Content="Далее" 
                        Style="{StaticResource PaginationButtonStyle}"
                        Width="80"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>