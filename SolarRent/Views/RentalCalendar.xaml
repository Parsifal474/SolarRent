<Window x:Class="SolarRent.RentalCalendar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Календарь аренды" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2E2EFF"/>
        <SolidColorBrush x:Key="ActiveBrush" Color="#4DD0E1"/>
        <SolidColorBrush x:Key="BookingBrush" Color="#FFF176"/>
        <SolidColorBrush x:Key="OverdueBrush" Color="#EF5350"/>
        <SolidColorBrush x:Key="AvailableBrush" Color="#E0E0E0"/>

        <!-- Стиль заголовка -->
        <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2E2EFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки статуса -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- Стиль для кнопки действия -->
        <Style x:Key="IssueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#81C784"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#66BB6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E57373"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF5350"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточки аренды -->
        <Style x:Key="RentalCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Стиль для дня календаря -->
        <Style x:Key="CalendarDayStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="1"
                                BorderBrush="#E0E0E0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlue}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Календарь аренды" 
                           Style="{StaticResource HeaderTitleStyle}"/>

                <Button Grid.Column="1" 
                        Content="Новое оборудование" 
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Календарь -->
            <Border Grid.Column="0" Background="#E8E8E8" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Выбранное оборудование -->
                    <TextBlock Grid.Row="0" 
                               Text="Выбранное оборудование:" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="#555555"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1" 
                            Background="White" 
                            CornerRadius="6" 
                            Padding="15" 
                            Margin="0,0,0,20"
                            MinHeight="50">
                        <TextBlock Text="" Foreground="#999999" FontStyle="Italic"/>
                    </Border>

                    <!-- Заголовок календаря -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="&lt;" FontSize="18" FontWeight="Bold" 
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="10,5" Foreground="#333333"/>

                        <TextBlock Grid.Column="1" Text="Март 2025" FontSize="18" FontWeight="Bold" 
                                   Foreground="#333333" HorizontalAlignment="Center"/>

                        <Button Grid.Column="2" Content="&gt;" FontSize="18" FontWeight="Bold" 
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="10,5" Foreground="#333333"/>
                    </Grid>

                    <!-- Сетка календаря -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Дни недели -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Пн" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="1" Text="Вт" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="2" Text="Ср" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="3" Text="Чт" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="4" Text="Пт" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="5" Text="Сб" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="6" Text="Вс" FontWeight="SemiBold" 
                                           Foreground="#666666" HorizontalAlignment="Center" Padding="5"/>
                            </Grid>

                            <!-- Дни месяца -->
                            <UniformGrid Grid.Row="1" Rows="5" Margin="0,10,0,0">
                                <!-- Week 1 -->
                                <Button Style="{StaticResource CalendarDayStyle}"/>
                                <Button Style="{StaticResource CalendarDayStyle}"/>
                                <Button Style="{StaticResource CalendarDayStyle}"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="1"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="2"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="3"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="4"/>

                                <!-- Week 2 -->
                                <Button Style="{StaticResource CalendarDayStyle}" Content="5"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="6"/>
                                <Border Background="#E3F2FD" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="7" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Аренда" FontSize="10" Foreground="#1976D2" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#E3F2FD" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="8" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Аренда" FontSize="10" Foreground="#1976D2" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#E3F2FD" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Аренда" FontSize="10" Foreground="#1976D2" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="10"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="11"/>

                                <!-- Week 3 -->
                                <Button Style="{StaticResource CalendarDayStyle}" Content="12"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="13"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="14"/>
                                <Border Background="#FFF9C4" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Бронь" FontSize="10" Foreground="#F57F17" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF9C4" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Бронь" FontSize="10" Foreground="#F57F17" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="17"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="18"/>

                                <!-- Week 4 -->
                                <Button Style="{StaticResource CalendarDayStyle}" Content="19"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="20"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="21"/>
                                <Border Background="#FFCDD2" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Просрочка" FontSize="10" Foreground="#C62828" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFCDD2" CornerRadius="4" Padding="8">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="23" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Просрочка" FontSize="10" Foreground="#C62828" 
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="24"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="25"/>

                                <!-- Week 5 -->
                                <Button Style="{StaticResource CalendarDayStyle}" Content="26"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="27"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="28"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="29"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="30"/>
                                <Button Style="{StaticResource CalendarDayStyle}" Content="31"/>
                                <Button Style="{StaticResource CalendarDayStyle}"/>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <!-- Легенда -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Ellipse Width="12" Height="12" Fill="#4DD0E1" Margin="0,0,5,0"/>
                            <TextBlock Text="Активна" VerticalAlignment="Center" Foreground="#555555"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Ellipse Width="12" Height="12" Fill="#FFF176" Margin="0,0,5,0"/>
                            <TextBlock Text="Бронь" VerticalAlignment="Center" Foreground="#555555"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Ellipse Width="12" Height="12" Fill="#EF5350" Margin="0,0,5,0"/>
                            <TextBlock Text="Просрочка" VerticalAlignment="Center" Foreground="#555555"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="12" Height="12" Fill="#E0E0E0" Margin="0,0,5,0"/>
                            <TextBlock Text="Доступно" VerticalAlignment="Center" Foreground="#555555"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Правая панель - Список аренд -->
            <Border Grid.Column="1" Background="#E8E8E8" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Предоставление аренды" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="#555555"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Rental Card 1 - Бронь -->
                            <Border Style="{StaticResource RentalCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="#2131" FontSize="16" 
                                                   FontWeight="Bold" Foreground="#333333"/>

                                        <Border Grid.Column="1" Background="#FFF176" CornerRadius="8" 
                                                Padding="10,4">
                                            <TextBlock Text="бронь" Foreground="#F57F17" 
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="Солнечная панель 300W" 
                                               FontSize="15" Foreground="#333333" 
                                               Margin="0,8,0,4"/>

                                    <TextBlock Grid.Row="2" Text='ООО "Энергия"' 
                                               FontSize="14" Foreground="#666666" 
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Text="15 мар - 20 мар" 
                                               FontSize="13" Foreground="#888888" 
                                               Margin="0,0,0,12"/>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Выдать" 
                                                Style="{StaticResource IssueButtonStyle}"
                                                HorizontalAlignment="Left"/>

                                        <Button Grid.Column="1" Content="Отменить" 
                                                Style="{StaticResource CancelButtonStyle}"
                                                HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Rental Card 2 - Активна -->
                            <Border Style="{StaticResource RentalCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="#2131" FontSize="16" 
                                                   FontWeight="Bold" Foreground="#333333"/>

                                        <Border Grid.Column="1" Background="#4DD0E1" CornerRadius="8" 
                                                Padding="10,4">
                                            <TextBlock Text="Активна" Foreground="White" 
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="Солнечная панель 300W" 
                                               FontSize="15" Foreground="#333333" 
                                               Margin="0,8,0,4"/>

                                    <TextBlock Grid.Row="2" Text='ООО "Энергия"' 
                                               FontSize="14" Foreground="#666666" 
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Text="15 мар - 20 мар" 
                                               FontSize="13" Foreground="#888888" 
                                               Margin="0,0,0,12"/>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Выдать" 
                                                Style="{StaticResource IssueButtonStyle}"
                                                HorizontalAlignment="Left"/>

                                        <Button Grid.Column="1" Content="Отменить" 
                                                Style="{StaticResource CancelButtonStyle}"
                                                HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Rental Card 3 - Бронь -->
                            <Border Style="{StaticResource RentalCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="#2131" FontSize="16" 
                                                   FontWeight="Bold" Foreground="#333333"/>

                                        <Border Grid.Column="1" Background="#FFF176" CornerRadius="8" 
                                                Padding="10,4">
                                            <TextBlock Text="бронь" Foreground="#F57F17" 
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="Солнечная панель 300W" 
                                               FontSize="15" Foreground="#333333" 
                                               Margin="0,8,0,4"/>

                                    <TextBlock Grid.Row="2" Text='ООО "Энергия"' 
                                               FontSize="14" Foreground="#666666" 
                                               Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Text="15 мар - 20 мар" 
                                               FontSize="13" Foreground="#888888" 
                                               Margin="0,0,0,12"/>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Выдать" 
                                                Style="{StaticResource IssueButtonStyle}"
                                                HorizontalAlignment="Left"/>

                                        <Button Grid.Column="1" Content="Отменить" 
                                                Style="{StaticResource CancelButtonStyle}"
                                                HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>