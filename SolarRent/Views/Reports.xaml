<Window x:Class="SolarRent.Views.Reports"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolarRent - Отчеты и аналитика" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2E2EFF"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E0E0FF"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF5350"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#66BB6A"/>

        <!-- Стиль заголовка -->
        <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль кнопок в шапке -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2E2EFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль карточки статистики -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль карточки должника -->
        <Style x:Key="DebtorCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Стиль карточки менеджера -->
        <Style x:Key="ManagerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Стиль кнопки -->
        <Style x:Key="ShowAllButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EF5350"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlue}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Отчеты и аналитика" 
                           Style="{StaticResource HeaderTitleStyle}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="За месяц" Style="{StaticResource HeaderButtonStyle}"/>
                    <Button Content="Экспорт" Style="{StaticResource HeaderButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Карточки статистики -->
        <Border Grid.Row="1" Background="White" Padding="20,15" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1 -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="2312" Style="{StaticResource StatValueStyle}"/>
                        <TextBlock Text="Выручка за период" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="2.345.342" Style="{StaticResource StatValueStyle}"/>
                        <TextBlock Text="Количество заказов" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="343" Style="{StaticResource StatValueStyle}"/>
                        <TextBlock Text="Новые клиенты" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Card 4 -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="2133" Style="{StaticResource StatValueStyle}"/>
                        <TextBlock Text="Средний чек" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Должники -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Список должников" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Debtor Card 1 -->
                            <Border Style="{StaticResource DebtorCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказ #2323" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="5 дней просрочки" 
                                               FontSize="14"
                                               Foreground="#EF5350"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Debtor Card 2 -->
                            <Border Style="{StaticResource DebtorCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказ #2323" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="5 дней просрочки" 
                                               FontSize="14"
                                               Foreground="#EF5350"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Debtor Card 3 -->
                            <Border Style="{StaticResource DebtorCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text='ООО "СтройТех"' 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказ #2323" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="5 дней просрочки" 
                                               FontSize="14"
                                               Foreground="#EF5350"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" 
                            Content="Показать всех должников" 
                            Style="{StaticResource ShowAllButtonStyle}"
                            Margin="0,15,0,0"/>
                </Grid>
            </Border>

            <!-- Правая панель - Эффективность менеджеров -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Эффективность менеджеров" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Manager Card 1 -->
                            <Border Style="{StaticResource ManagerCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="Иванова К.В." 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="34.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказов #232" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Выручка" 
                                               FontSize="14"
                                               Foreground="#2E2EFF"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Manager Card 2 -->
                            <Border Style="{StaticResource ManagerCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="Иваа К.В." 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="74.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказов #232" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Выручка" 
                                               FontSize="14"
                                               Foreground="#2E2EFF"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Manager Card 3 -->
                            <Border Style="{StaticResource ManagerCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="нова К.В." 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="14.444" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="#333333"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Заказов #232" 
                                               FontSize="14"
                                               Foreground="#666666"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Выручка" 
                                               FontSize="14"
                                               Foreground="#2E2EFF"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>